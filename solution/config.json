  "session_drift_rate": 0.01,
  "context_reset_every": 0,
  "tool_error_rate": 0.05,
  "catalog_override": {},
  "route_rules": [],
  "planner": true,
  "verify": true,
  "self_consistency": 1,
  "tool_budget": 5
}
